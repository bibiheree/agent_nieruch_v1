    {
      "parameters": {
        "jsCode": "// Iteracja po wszystkich pobranych elementach z kalendarza (zgodnie ze standardem n8n v1+)\nfor (const item of $input.all()) {\n  const desc = item.json.description || \"\";\n  \n  // Wyciąganie telefonu i klienta z opisu za pomocą wyrażeń regularnych\n  const phoneMatch = desc.match(/telefon:\\s*(\\+?\\d+)/i);\n  const clientMatch = desc.match(/klient:\\s*([^\\n]+)/i);\n\n  // Wyciąganie nazwy agenta z tytułu spotkania lub przypisanie domyślnego\n  const summary = item.json.summary || \"\";\n  const agentMatch = summary.match(/(?:agent|prowadzący):\\s*([^\\n]+)/i);\n\n  // Formatowanie adresu z tytułu (np. \"Spotkanie: Bracka 4\" -> \"Bracka 4\")\n  const cleanAddress = summary.replace(/Spotkanie:\\s*/i, \"\").trim();\n\n  // Zapisanie sparsowanych danych bezpośrednio do obiektu wyjściowego\n  item.json.client_phone = phoneMatch ? phoneMatch[1].trim() : \"\";\n  item.json.client_name = clientMatch ? clientMatch[1].trim() : \"Klient\";\n  item.json.agent_name = agentMatch ? agentMatch[1].trim() : \"Hubert\";\n  item.json.clean_address = cleanAddress;\n}\n\nreturn $input.all();"
      },
