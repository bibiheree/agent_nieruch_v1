    {
      "parameters": {
        "jsCode": "// Rozdzielamy tytuł po znaku przecinka\nfor (const item of $input.all()) {\n  const summary = item.json.summary || \"\";\n  \n  // Splitujemy tekst po przecinku i usuwamy białe znaki\n  const parts = summary.split(',').map(s => s.trim());\n\n  if (parts.length >= 4) {\n    item.json.meeting_type = parts[0];\n    item.json.client_name = parts[1];\n    item.json.phone = parts[2];\n    item.json.address = parts[3];\n  } else {\n    // Fallback: jeśli wpiszesz coś źle, żeby workflow się nie wywalił\n    item.json.meeting_type = \"Brak\";\n    item.json.client_name = summary;\n  }\n\n  // Nazwa kalendarza Google = imie agenta (np. Hubert, Wiktoria, Jakub)\n  item.json.agent_name = item.json.organizer?.displayName || \"\";\n}\n\nreturn $input.all();"
      },
